<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="goqu.Views.HomeView"
             Background="#0A0A0A">

    <UserControl.Styles>
        <!-- Module card button — custom template, no Fluent chrome -->
        <Style Selector="Button.ModuleCard">
            <Setter Property="Background" Value="#0E1016"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#191D26"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.ModuleCard:pointerover">
            <Setter Property="Background" Value="#12161F"/>
            <Setter Property="BorderBrush" Value="#252C3A"/>
        </Style>
        <Style Selector="Button.ModuleCard:pressed">
            <Setter Property="Background" Value="#0A0D14"/>
        </Style>
        <Style Selector="Button.ModuleCard.Disabled">
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style Selector="Button.ModuleCard.Disabled:pointerover">
            <Setter Property="Background" Value="#0E1016"/>
            <Setter Property="BorderBrush" Value="#191D26"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,1,*">

        <!-- ── Greeting header ── -->
        <Border Grid.Row="0" Background="#0C0F18" Padding="32,24,32,22">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock x:Name="GreetingLabel"
                               Text="GOOD MORNING"
                               FontSize="9" FontWeight="Bold"
                               Foreground="#FF9500"
                               LetterSpacing="2"/>
                    <TextBlock x:Name="DateLabel"
                               Text=""
                               FontSize="26" FontWeight="Black"
                               Foreground="#EBFFFF"/>
                    <TextBlock x:Name="AccountLabel"
                               Text=""
                               FontSize="12"
                               Foreground="#3A4252"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3" HorizontalAlignment="Right">
                    <TextBlock x:Name="TimeLabel"
                               Text=""
                               FontSize="22" FontWeight="Light"
                               Foreground="#1C2430"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="LOCAL TIME"
                               FontSize="8" FontWeight="Bold"
                               Foreground="#1A2030"
                               HorizontalAlignment="Right"
                               LetterSpacing="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Row="1" Fill="#141820"/>

        <!-- ── Main scroll area ── -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,28,32,36" Spacing="32">

                <!-- Account health strip -->
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="ACCOUNT HEALTH"
                                   FontSize="9" FontWeight="Bold"
                                   Foreground="#1C2430"
                                   LetterSpacing="1"
                                   VerticalAlignment="Center"/>
                        <Rectangle Width="1" Height="10" Fill="#1C2430" VerticalAlignment="Center"/>
                        <TextBlock x:Name="HealthSubtitle"
                                   Text="all time"
                                   FontSize="9"
                                   Foreground="#1A2030"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 4-wide health row — different proportion than journal's 6-box strip -->
                    <Grid ColumnDefinitions="*,1,*,1,*,1,*">

                        <!-- Total P&L -->
                        <Border Grid.Column="0" Background="#0E1016" CornerRadius="4" Padding="18,14" ClipToBounds="True">
                            <Grid RowDefinitions="3,*">
                                <Rectangle Grid.Row="0" x:Name="PnlAccent" Fill="#1A2030" Margin="-18,-14,-18,0"/>
                                <StackPanel Grid.Row="1" Spacing="6" Margin="0,10,0,0">
                                    <TextBlock Text="TOTAL P&amp;L" FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
                                    <TextBlock x:Name="StatPnl" Text="—"
                                               FontSize="28" FontWeight="Black" Foreground="#EBFFFF"/>
                                    <TextBlock x:Name="StatPnlSub" Text=""
                                               FontSize="11" Foreground="#3A4252"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Rectangle Grid.Column="1" Fill="#141820"/>

                        <!-- Win Rate -->
                        <Border Grid.Column="2" Background="#0E1016" CornerRadius="4" Padding="18,14" ClipToBounds="True">
                            <Grid RowDefinitions="3,*">
                                <Rectangle Grid.Row="0" Fill="#1A2030" Margin="-18,-14,-18,0"/>
                                <StackPanel Grid.Row="1" Spacing="6" Margin="0,10,0,0">
                                    <TextBlock Text="WIN RATE" FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
                                    <TextBlock x:Name="StatWR" Text="—"
                                               FontSize="28" FontWeight="Black" Foreground="#EBFFFF"/>
                                    <TextBlock x:Name="StatWRSub" Text=""
                                               FontSize="11" Foreground="#3A4252"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Rectangle Grid.Column="3" Fill="#141820"/>

                        <!-- Expectancy -->
                        <Border Grid.Column="4" Background="#0E1016" CornerRadius="4" Padding="18,14" ClipToBounds="True">
                            <Grid RowDefinitions="3,*">
                                <Rectangle Grid.Row="0" Fill="#1A2030" Margin="-18,-14,-18,0"/>
                                <StackPanel Grid.Row="1" Spacing="6" Margin="0,10,0,0">
                                    <TextBlock Text="EXPECTANCY" FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
                                    <TextBlock x:Name="StatExp" Text="—"
                                               FontSize="28" FontWeight="Black" Foreground="#EBFFFF"/>
                                    <TextBlock x:Name="StatExpSub" Text=""
                                               FontSize="11" Foreground="#3A4252"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Rectangle Grid.Column="5" Fill="#141820"/>

                        <!-- Open Positions -->
                        <Border Grid.Column="6" Background="#0E1016" CornerRadius="4" Padding="18,14" ClipToBounds="True">
                            <Grid RowDefinitions="3,*">
                                <Rectangle Grid.Row="0" Fill="#001428" Margin="-18,-14,-18,0"/>
                                <StackPanel Grid.Row="1" Spacing="6" Margin="0,10,0,0">
                                    <TextBlock Text="OPEN POSITIONS" FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
                                    <TextBlock x:Name="StatOpenPos" Text="0"
                                               FontSize="28" FontWeight="Black" Foreground="#0085CD"/>
                                    <TextBlock x:Name="StatOpenRisk" Text=""
                                               FontSize="11" Foreground="#3A4252"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </Grid>
                </StackPanel>

                <!-- Module cards -->
                <StackPanel Spacing="10">
                    <TextBlock Text="MODULES"
                               FontSize="9" FontWeight="Bold"
                               Foreground="#1C2430"
                               LetterSpacing="1"/>

                    <!-- Row 1 -->
                    <Grid ColumnDefinitions="*,12,*,12,*">

                        <!-- Trade Journal -->
                        <Button Grid.Column="0" Classes="ModuleCard" Click="OnOpenJournal">
                            <Grid ColumnDefinitions="4,*">
                                <Border Grid.Column="0" Background="#038C4C" CornerRadius="4,0,0,4"/>
                                <StackPanel Grid.Column="1" Margin="18,18,18,18" Spacing="8">
                                    <TextBlock Text="TRADE JOURNAL"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#038C4C"
                                               LetterSpacing="1"/>
                                    <TextBlock Text="Log trades, track P&amp;L, and analyze your performance history."
                                               FontSize="12" Foreground="#4A5568"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <TextBlock x:Name="CardJournalStat" Text="0 trades"
                                                   FontSize="11" Foreground="#2A3040"/>
                                        <TextBlock x:Name="CardJournalR" Text=""
                                                   FontSize="11" Foreground="#2A3040"/>
                                    </StackPanel>
                                    <TextBlock Text="OPEN JOURNAL  →"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="#038C4C" LetterSpacing="1"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Research -->
                        <Button Grid.Column="2" Classes="ModuleCard Disabled" IsEnabled="False">
                            <Grid ColumnDefinitions="4,*">
                                <Border Grid.Column="0" Background="#0085CD" CornerRadius="4,0,0,4"/>
                                <StackPanel Grid.Column="1" Margin="18,18,18,18" Spacing="8">
                                    <TextBlock Text="RESEARCH"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#0085CD"
                                               LetterSpacing="1"/>
                                    <TextBlock Text="Deep-dive market research, sector dossiers, and company analysis."
                                               FontSize="12" Foreground="#4A5568"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="COMING SOON"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="#1C2430" LetterSpacing="1"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Edge Discovery -->
                        <Button Grid.Column="4" Classes="ModuleCard Disabled" IsEnabled="False">
                            <Grid ColumnDefinitions="4,*">
                                <Border Grid.Column="0" Background="#FFE101" CornerRadius="4,0,0,4"/>
                                <StackPanel Grid.Column="1" Margin="18,18,18,18" Spacing="8">
                                    <TextBlock Text="EDGE DISCOVERY"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#FFE101"
                                               LetterSpacing="1"/>
                                    <TextBlock Text="Discover and quantify your statistical edge across setups and regimes."
                                               FontSize="12" Foreground="#4A5568"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="COMING SOON"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="#1C2030" LetterSpacing="1"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                    </Grid>

                    <!-- Row 2 -->
                    <Grid ColumnDefinitions="*,12,*,12,*">

                        <!-- Screener -->
                        <Button Grid.Column="0" Classes="ModuleCard Disabled" IsEnabled="False">
                            <Grid ColumnDefinitions="4,*">
                                <Border Grid.Column="0" Background="#FF9500" CornerRadius="4,0,0,4"/>
                                <StackPanel Grid.Column="1" Margin="18,18,18,18" Spacing="8">
                                    <TextBlock Text="SCREENER"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#FF9500"
                                               LetterSpacing="1"/>
                                    <TextBlock Text="Scan for technical and fundamental setups that match your criteria."
                                               FontSize="12" Foreground="#4A5568"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="COMING SOON"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="#1C2030" LetterSpacing="1"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Income / Sweep -->
                        <Button Grid.Column="2" Classes="ModuleCard Disabled" IsEnabled="False">
                            <Grid ColumnDefinitions="4,*">
                                <Border Grid.Column="0" Background="#038C4C" CornerRadius="4,0,0,4"/>
                                <StackPanel Grid.Column="1" Margin="18,18,18,18" Spacing="8">
                                    <TextBlock Text="INCOME / SWEEP"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#038C4C"
                                               LetterSpacing="1"/>
                                    <TextBlock Text="Track premium collection, dividend sweeps, and recurring income strategies."
                                               FontSize="12" Foreground="#4A5568"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="COMING SOON"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="#1C2030" LetterSpacing="1"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Placeholder slot -->
                        <Border Grid.Column="4" Background="#0A0C10"
                                CornerRadius="4"
                                BorderBrush="#0E1016"
                                BorderThickness="1"/>

                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
