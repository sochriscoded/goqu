<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:goqu.Views.Journal"
             x:Class="goqu.Views.Journal.TradeLogTab"
             Background="#0A0A0A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10"
                    Margin="16,0,16,0" VerticalAlignment="Center">
            <ComboBox x:Name="FilterStatus" SelectedIndex="0" FontSize="12" Height="28" MinWidth="110">
                <ComboBoxItem Content="All Trades"/>
                <ComboBoxItem Content="Open Only"/>
                <ComboBoxItem Content="Closed Only"/>
            </ComboBox>
            <ComboBox x:Name="FilterDirection" SelectedIndex="0" FontSize="12" Height="28" MinWidth="100">
                <ComboBoxItem Content="All Directions"/>
                <ComboBoxItem Content="Long"/>
                <ComboBoxItem Content="Short"/>
                <ComboBoxItem Content="Neutral"/>
            </ComboBox>
            <TextBox x:Name="FilterSymbol"
                     PlaceholderText="Symbol…"
                     FontSize="12" Width="90" Height="28" Padding="8,4"/>
            <Button Content="APPLY"
                    Background="#1A2030" Foreground="#EBFFFF"
                    FontSize="11" FontWeight="Bold"
                    Padding="12,0" Height="28" CornerRadius="3"
                    Cursor="Hand"
                    Click="OnApplyFilter"/>
        </StackPanel>

        <Rectangle Grid.Row="1" Fill="#141820"/>

        <!-- Column headers -->
        <Grid Grid.Row="2" ColumnDefinitions="90,70,120,80,90,90,110,*"
              Margin="16,6,16,6">
            <TextBlock Grid.Column="0" Text="SYMBOL"     FontSize="8" FontWeight="Bold" Foreground="#2A3040" Margin="4,0,0,0"/>
            <TextBlock Grid.Column="1" Text="DIR"        FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
            <TextBlock Grid.Column="2" Text="STRATEGY"   FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
            <TextBlock Grid.Column="3" Text="STATUS"     FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
            <TextBlock Grid.Column="4" Text="RISK $"     FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
            <TextBlock Grid.Column="5" Text="P&amp;L"   FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
            <TextBlock Grid.Column="6" Text="R"          FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
            <TextBlock Grid.Column="7" Text="DATE"       FontSize="8" FontWeight="Bold" Foreground="#2A3040"/>
        </Grid>

        <Rectangle Grid.Row="3" Fill="#141820"/>

        <!-- Trade rows -->
        <ListBox Grid.Row="4"
                 x:Name="TradeList"
                 Background="Transparent"
                 BorderThickness="0"
                 Margin="8,0,8,0"
                 SelectionChanged="OnTradeSelected">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="8,0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Height" Value="34"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="#0E1118"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="#141820"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:LogTradeRow">
                    <Grid ColumnDefinitions="90,70,120,80,90,90,110,*">
                        <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#EBFFFF"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding DirGlyph}"
                                   FontSize="12" FontWeight="Bold" Foreground="{Binding DirColor}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Strategy}"
                                   FontSize="11" Foreground="#8090A0"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3" Text="{Binding StatusLabel}"
                                   FontSize="10" FontWeight="Bold" Foreground="{Binding StatusColor}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="{Binding Risk}"
                                   FontSize="12" Foreground="#EBFFFF" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="{Binding Pnl}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="{Binding PnlColor}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="{Binding R}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="{Binding RColor}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="{Binding Date}"
                                   FontSize="11" Foreground="#8090A0" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Rectangle Grid.Row="5" Fill="#141820"/>

        <!-- Action bar -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="10"
                    Margin="16,0,16,0" VerticalAlignment="Center">
            <Button x:Name="BtnClose"
                    Content="CLOSE TRADE"
                    Background="#1A2030" Foreground="#EBFFFF"
                    FontSize="11" FontWeight="Bold"
                    Padding="14,0" Height="28" CornerRadius="3"
                    Cursor="Hand" IsEnabled="False"
                    Click="OnCloseTrade"/>
            <TextBlock x:Name="TradeCountLabel"
                       Text="0 trades"
                       FontSize="11" Foreground="#3A4252"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
