<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:goqu.Views.Income"
             x:Class="goqu.Views.Income.IncomeView"
             Background="#060810">

    <UserControl.Styles>
        <Style Selector="Button.ITab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2A3A4A"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.ITab.Active">
            <Setter Property="Foreground" Value="#17A86C"/>
            <Setter Property="BorderBrush" Value="#17A86C"/>
        </Style>
        <Style Selector="Button.ITab:pointerover">
            <Setter Property="Foreground" Value="#6070A0"/>
        </Style>

        <Style Selector="Button.SleeveChip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3A4A5A"/>
            <Setter Property="BorderBrush" Value="#141820"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.SleeveChip.Active">
            <Setter Property="Background" Value="#0A1608"/>
            <Setter Property="Foreground" Value="#17A86C"/>
            <Setter Property="BorderBrush" Value="#17A86C"/>
        </Style>
        <Style Selector="Button.SleeveChip:pointerover">
            <Setter Property="Foreground" Value="#6070A0"/>
        </Style>

        <Style Selector="Button.PrimaryBtn">
            <Setter Property="Background" Value="#0A1A0E"/>
            <Setter Property="Foreground" Value="#17A86C"/>
            <Setter Property="BorderBrush" Value="#184D28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.PrimaryBtn:pointerover">
            <Setter Property="Background" Value="#112A14"/>
            <Setter Property="BorderBrush" Value="#17A86C"/>
        </Style>

        <Style Selector="Button.SweepBtn">
            <Setter Property="Background" Value="#17A86C"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#17A86C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.SweepBtn:pointerover">
            <Setter Property="Background" Value="#14906A"/>
        </Style>
        <Style Selector="Button.SweepBtn:disabled">
            <Setter Property="Background" Value="#0A1A0E"/>
            <Setter Property="Foreground" Value="#1A3020"/>
            <Setter Property="BorderBrush" Value="#0A1A0E"/>
        </Style>

        <Style Selector="Button.FilterChip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2A3A4A"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.FilterChip.Active">
            <Setter Property="Background" Value="#0A1608"/>
            <Setter Property="Foreground" Value="#17A86C"/>
            <Setter Property="BorderBrush" Value="#184D28"/>
        </Style>
        <Style Selector="Button.FilterChip:pointerover">
            <Setter Property="Foreground" Value="#6070A0"/>
        </Style>

        <Style Selector="TextBlock.SLabel">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2A3240"/>
            <Setter Property="LetterSpacing" Value="1"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#0A0D18" BorderThickness="0,0,0,1">
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ Border">
            <Setter Property="Background" Value="#0A0C18"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ Border">
            <Setter Property="Background" Value="#0D1020"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="54,1,44,1,*">

        <!-- ══ Header ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Background="#07080E">
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Spacing="12" VerticalAlignment="Center"
                        Margin="24,0,0,0">
                <Border Width="4" Height="20" Background="#17A86C" CornerRadius="2"/>
                <TextBlock Text="INCOME / SWEEP ENGINE"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#EBFFFF" VerticalAlignment="Center"/>
                <TextBlock x:Name="IncomeSubtitle"
                           FontSize="11" Foreground="#2A3A4A"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="2" Classes="PrimaryBtn"
                    Content="REFRESH" Margin="0,0,20,0"
                    Click="OnRefresh"/>
        </Grid>

        <Rectangle Grid.Row="1" Fill="#0E1020"/>

        <!-- ══ Tab bar ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#06080E">
            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">
                <Button x:Name="TabOverview"   Classes="ITab Active" Content="OVERVIEW"     Tag="overview"    Height="44" Click="OnTabClick"/>
                <Button x:Name="TabHoldings"   Classes="ITab"        Content="HOLDINGS"     Tag="holdings"    Height="44" Click="OnTabClick"/>
                <Button x:Name="TabDividends"  Classes="ITab"        Content="DIVIDENDS"    Tag="dividends"   Height="44" Click="OnTabClick"/>
                <Button x:Name="TabSweep"      Classes="ITab"        Content="SWEEP LEDGER" Tag="sweep"       Height="44" Click="OnTabClick"/>
                <Button x:Name="TabDGScreen"   Classes="ITab"        Content="DG SCREEN"    Tag="dgscreen"    Height="44" Click="OnTabClick"/>
            </StackPanel>
        </Border>

        <Rectangle Grid.Row="3" Fill="#0E1020"/>

        <!-- ══ Tab content ════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="4" HorizontalScrollBarVisibility="Disabled">
            <Grid>

                <!-- ── OVERVIEW ─────────────────────────────────────────────── -->
                <StackPanel x:Name="OverviewPanel" Margin="28,24,28,28" Spacing="16">

                    <!-- Two-sleeve summary -->
                    <Grid ColumnDefinitions="*,16,*">

                        <!-- INDEX CORE -->
                        <Border Grid.Column="0" Background="#000A18"
                                BorderBrush="#001530" BorderThickness="1"
                                CornerRadius="8" Padding="0">
                            <Grid RowDefinitions="4,*">
                                <Border Grid.Row="0" Background="#0085CD"
                                        CornerRadius="8,8,0,0"/>
                                <StackPanel Grid.Row="1" Margin="18,14,18,16" Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="INDEX CORE"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="#0085CD" LetterSpacing="1"/>
                                        <TextBlock Text="·  passive benchmark sleeve"
                                                   FontSize="10" Foreground="#1A3050"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock x:Name="IndexCostBasis" Text="—"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Text="COST BASIS" Classes="SLabel"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock x:Name="IndexHoldings" Text="—"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Text="POSITIONS" Classes="SLabel"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="#000D20" BorderBrush="#001030"
                                            BorderThickness="1" CornerRadius="4" Padding="10,7">
                                        <TextBlock FontSize="11" Foreground="#2A4060" TextWrapping="Wrap">
                                            The benchmark sleeve. Every active-engine win must beat this sleeve's return to justify the effort.
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- DIVIDEND GROWTH -->
                        <Border Grid.Column="2" Background="#040F08"
                                BorderBrush="#0A1E10" BorderThickness="1"
                                CornerRadius="8" Padding="0">
                            <Grid RowDefinitions="4,*">
                                <Border Grid.Row="0" Background="#17A86C"
                                        CornerRadius="8,8,0,0"/>
                                <StackPanel Grid.Row="1" Margin="18,14,18,16" Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="DIVIDEND GROWTH"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="#17A86C" LetterSpacing="1"/>
                                        <TextBlock Text="·  income sleeve"
                                                   FontSize="10" Foreground="#0A2010"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock x:Name="DivCostBasis" Text="—"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Text="COST BASIS" Classes="SLabel"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock x:Name="DivHoldings" Text="—"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Text="POSITIONS" Classes="SLabel"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock x:Name="DivYOC" Text="—"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#17A86C"/>
                                            <TextBlock Text="YIELD ON COST" Classes="SLabel"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock x:Name="DivProjIncome" Text="—"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#17A86C"/>
                                            <TextBlock Text="PROJ. ANNUAL INCOME" Classes="SLabel"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 5 KPI tiles -->
                    <Grid ColumnDefinitions="*,10,*,10,*,10,*,10,*">
                        <Border Grid.Column="0" Background="#08090E"
                                BorderBrush="#141820" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="KpiYTDDiv" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#17A86C"/>
                                <TextBlock Text="YTD DIVIDENDS" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#08090E"
                                BorderBrush="#141820" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="KpiRunRate" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#17A86C"/>
                                <TextBlock Text="RUN-RATE / YR" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="#08090E"
                                BorderBrush="#141820" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="KpiYOC" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#EBFFFF"/>
                                <TextBlock Text="YIELD ON COST" Classes="SLabel"/>
                                <TextBlock Text="div growth sleeve" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Background="#08090E"
                                BorderBrush="#141820" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="KpiTotalCost" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#EBFFFF"/>
                                <TextBlock Text="TOTAL COST BASIS" Classes="SLabel"/>
                                <TextBlock Text="both sleeves" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="8" Background="#040F08"
                                BorderBrush="#0A1E10" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="KpiTotalSwept" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#17A86C"/>
                                <TextBlock Text="CUMULATIVE SWEPT" Classes="SLabel"/>
                                <TextBlock Text="locked-in from trading" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Crossover projection -->
                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="20,16">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="4" Height="16" Background="#17A86C" CornerRadius="2"/>
                                <TextBlock Text="CROSSOVER PROJECTION"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#EBFFFF" LetterSpacing="0.5"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="years until dividends cover your target take-home"
                                           FontSize="10" Foreground="#2A3A4A"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="*,24,200">
                                <StackPanel Grid.Column="0" Spacing="10">
                                    <Grid ColumnDefinitions="*,16,*,16,*">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock x:Name="CrossoverCurrent" Text="—"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#17A86C"/>
                                            <TextBlock Text="CURRENT / YR" Classes="SLabel"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="→"
                                                   FontSize="16" Foreground="#1A2A1A"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <StackPanel Grid.Column="2" Spacing="3">
                                            <TextBlock x:Name="CrossoverTarget" Text="—"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Text="TARGET / YR" Classes="SLabel"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="="
                                                   FontSize="16" Foreground="#1A2A1A"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <StackPanel Grid.Column="4" Spacing="3">
                                            <TextBlock x:Name="CrossoverETA" Text="—"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="#FFE101"/>
                                            <TextBlock Text="ESTIMATED ETA" Classes="SLabel"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Progress bar -->
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="CrossoverProgress"
                                                   Text="0% of target"
                                                   FontSize="10" Foreground="#2A3A4A"/>
                                        <Border Height="6" Background="#0A0C14"
                                                CornerRadius="3">
                                            <Border x:Name="CrossoverBar"
                                                    Height="6" Background="#17A86C"
                                                    CornerRadius="3" Width="0"
                                                    HorizontalAlignment="Left"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <!-- Target input -->
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="ANNUAL TARGET ($)" Classes="SLabel"/>
                                    <Border Background="#060810" BorderBrush="#141820"
                                            BorderThickness="1" CornerRadius="4" Padding="8,6">
                                        <TextBox x:Name="CrossoverTargetInput"
                                                 Text="60000"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#EBFFFF" FontSize="12"
                                                 FontWeight="SemiBold"
                                                 TextChanged="OnTargetChanged"/>
                                    </Border>
                                    <TextBlock Text="est. div growth rate (%/yr)" Classes="SLabel" Margin="0,4,0,0"/>
                                    <Border Background="#060810" BorderBrush="#141820"
                                            BorderThickness="1" CornerRadius="4" Padding="8,6">
                                        <TextBox x:Name="GrowthRateInput"
                                                 Text="7"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#EBFFFF" FontSize="12"
                                                 TextChanged="OnTargetChanged"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Sweep flow summary -->
                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="20,14">
                        <Grid ColumnDefinitions="*,1,*,1,*">
                            <StackPanel Grid.Column="0" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="ACTIVE ENGINE" Classes="SLabel" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="SweepNetPnl" Text="—"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="#EBFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="net realized P&amp;L" FontSize="10"
                                           Foreground="#2A3A4A" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#0E1020" Width="1"/>
                            <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="SWEEP PUMP" Classes="SLabel" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                    <TextBlock x:Name="SweepPctLabel" Text="—"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="#FF9500"/>
                                    <TextBlock Text="of net" FontSize="12"
                                               Foreground="#2A3A4A" VerticalAlignment="Bottom"
                                               Margin="0,0,0,2"/>
                                </StackPanel>
                                <TextBlock x:Name="SweepAvailable" Text="—  available"
                                           FontSize="10" Foreground="#2A3A4A"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="3" Background="#0E1020" Width="1"/>
                            <StackPanel Grid.Column="4" Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="PASSIVE ENGINE" Classes="SLabel" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="SweepCumulative" Text="—"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="#17A86C" HorizontalAlignment="Center"/>
                                <TextBlock Text="cumulative locked-in" FontSize="10"
                                           Foreground="#2A3A4A" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- ── HOLDINGS ────────────────────────────────────────────── -->
                <StackPanel x:Name="HoldingsPanel" IsVisible="False"
                            Margin="28,20,28,28" Spacing="0">

                    <!-- Toolbar -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <Button x:Name="SleeveAll"      Classes="SleeveChip Active" Content="ALL"          Tag="all"          Click="OnSleeveFilter" Margin="0,0,4,0"/>
                            <Button x:Name="SleeveIndex"    Classes="SleeveChip"        Content="INDEX CORE"   Tag="index_core"   Click="OnSleeveFilter" Margin="0,0,4,0"/>
                            <Button x:Name="SleeveDivGrowth" Classes="SleeveChip"       Content="DIV GROWTH"   Tag="div_growth"   Click="OnSleeveFilter"/>
                        </StackPanel>
                        <Button Grid.Column="2" Classes="PrimaryBtn"
                                Content="+ ADD POSITION" Click="OnAddPosition"/>
                    </Grid>

                    <!-- Holdings table -->
                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="0">
                        <StackPanel Spacing="0">
                            <!-- Column headers -->
                            <Grid ColumnDefinitions="90,80,70,90,100,100,80,*"
                                  Margin="16,10,16,8">
                                <TextBlock Grid.Column="0" Text="SYMBOL"    Classes="SLabel"/>
                                <TextBlock Grid.Column="1" Text="SLEEVE"    Classes="SLabel"/>
                                <TextBlock Grid.Column="2" Text="SHARES"    Classes="SLabel"/>
                                <TextBlock Grid.Column="3" Text="AVG COST"  Classes="SLabel"/>
                                <TextBlock Grid.Column="4" Text="COST BASIS" Classes="SLabel"/>
                                <TextBlock Grid.Column="5" Text="MKT VALUE" Classes="SLabel"/>
                                <TextBlock Grid.Column="6" Text="YOC"       Classes="SLabel"/>
                                <TextBlock Grid.Column="7" Text="LOTS"      Classes="SLabel"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#141820"/>

                            <Border x:Name="HoldingsEmpty" Padding="16,20">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="No positions yet."
                                               FontSize="12" Foreground="#2A3240"/>
                                    <TextBlock FontSize="11" Foreground="#1A2430">
                                        Click + ADD POSITION to add your first holding.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <ListBox x:Name="HoldingsList"
                                     Background="Transparent" IsVisible="False">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="local:HoldingRow">
                                        <Grid ColumnDefinitions="90,80,70,90,100,100,80,*"
                                              Margin="16,9,16,9">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Symbol}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <Border Grid.Column="1"
                                                    Background="{Binding SleeveBg}"
                                                    CornerRadius="3" Padding="5,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SleeveLabel}"
                                                           FontSize="8" FontWeight="Bold"
                                                           Foreground="{Binding SleeveAccent}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Shares}"
                                                       FontSize="12" Foreground="#8090A8"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding AvgCost}"
                                                       FontSize="12" Foreground="#6070A0"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding CostBasis}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding MktValue}"
                                                       FontSize="12" Foreground="#3A4A5A"/>
                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding YOC}"
                                                       FontSize="12" Foreground="#17A86C"/>
                                            <TextBlock Grid.Column="7"
                                                       Text="{Binding LotCount}"
                                                       FontSize="12" Foreground="#3A4A5A"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── DIVIDENDS ────────────────────────────────────────────── -->
                <StackPanel x:Name="DividendsPanel" IsVisible="False"
                            Margin="28,20,28,28" Spacing="16">

                    <!-- Stats strip -->
                    <Grid ColumnDefinitions="*,12,*,12,*,12,*">
                        <Border Grid.Column="0" Background="#040F08"
                                BorderBrush="#0A1E10" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="3">
                                <TextBlock x:Name="DivYTDTotal" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#17A86C"/>
                                <TextBlock Text="YTD RECEIVED" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#08090E"
                                BorderBrush="#141820" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="3">
                                <TextBlock x:Name="DivRunRate" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#EBFFFF"/>
                                <TextBlock Text="ANNUALIZED RUN-RATE" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Background="#08090E"
                                BorderBrush="#141820" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="3">
                                <TextBlock x:Name="DivDripShares" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#EBFFFF"/>
                                <TextBlock Text="DRIP SHARES ADDED" Classes="SLabel"/>
                                <TextBlock Text="this year" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Background="#08090E"
                                BorderBrush="#141820" BorderThickness="1"
                                CornerRadius="6" Padding="14,12">
                            <StackPanel Spacing="3">
                                <TextBlock x:Name="DivCount" Text="—"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#EBFFFF"/>
                                <TextBlock Text="DIVIDENDS LOGGED" Classes="SLabel"/>
                                <TextBlock Text="all time" Classes="SLabel"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Toolbar -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="DIVIDEND LOG"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#2A3240" LetterSpacing="1"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="PrimaryBtn"
                                Content="+ LOG DIVIDEND" Click="OnLogDividend"/>
                    </Grid>

                    <!-- Dividend log table -->
                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="0">
                        <StackPanel Spacing="0">
                            <Grid ColumnDefinitions="100,80,90,80,100,80,*"
                                  Margin="16,10,16,8">
                                <TextBlock Grid.Column="0" Text="EX-DATE"       Classes="SLabel"/>
                                <TextBlock Grid.Column="1" Text="SYMBOL"        Classes="SLabel"/>
                                <TextBlock Grid.Column="2" Text="$/SHARE"       Classes="SLabel"/>
                                <TextBlock Grid.Column="3" Text="SHARES"        Classes="SLabel"/>
                                <TextBlock Grid.Column="4" Text="TOTAL"         Classes="SLabel"/>
                                <TextBlock Grid.Column="5" Text="PAY DATE"      Classes="SLabel"/>
                                <TextBlock Grid.Column="6" Text="DRIP"          Classes="SLabel"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#141820"/>

                            <Border x:Name="DividendsEmpty" Padding="16,20">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="No dividends logged yet."
                                               FontSize="12" Foreground="#2A3240"/>
                                    <TextBlock FontSize="11" Foreground="#1A2430">
                                        Click + LOG DIVIDEND to record a received payment. Enable DRIP to track reinvested shares.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <ListBox x:Name="DividendsList"
                                     Background="Transparent" IsVisible="False">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="local:DividendRow">
                                        <Grid ColumnDefinitions="100,80,90,80,100,80,*"
                                              Margin="16,8,16,8">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ExDate}"
                                                       FontSize="12" Foreground="#8090A8"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Symbol}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AmtPerShare}"
                                                       FontSize="12" Foreground="#6070A0"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Shares}"
                                                       FontSize="12" Foreground="#6070A0"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Total}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#17A86C"/>
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding PayDate}"
                                                       FontSize="12" Foreground="#3A4A5A"/>
                                            <Border Grid.Column="6"
                                                    Background="{Binding ReinvestedBg}"
                                                    CornerRadius="3" Padding="5,2"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding ReinvestedLabel}"
                                                           FontSize="8" FontWeight="Bold"
                                                           Foreground="{Binding ReinvestedColor}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── SWEEP LEDGER ──────────────────────────────────────────── -->
                <StackPanel x:Name="SweepPanel" IsVisible="False"
                            Margin="28,20,28,28" Spacing="16">

                    <!-- Sweep rule box -->
                    <Border Background="#0C0900" BorderBrush="#3A2E00"
                            BorderThickness="1" CornerRadius="6" Padding="20,16">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Width="4" Height="16" Background="#FF9500" CornerRadius="2"/>
                                <TextBlock Text="SWEEP RULE"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#FF9500" LetterSpacing="0.5"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="Auto,12,100,12,*,12,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Sweep"
                                           FontSize="14" Foreground="#8090A8"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="2"
                                        Background="#060810" BorderBrush="#2A2000"
                                        BorderThickness="1" CornerRadius="4" Padding="10,6">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <TextBox x:Name="SweepPctInput"
                                                 Text="25"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#FF9500" FontSize="16"
                                                 FontWeight="Bold" Width="50"
                                                 TextChanged="OnSweepPctChanged"/>
                                        <TextBlock Text="%" FontSize="16"
                                                   Foreground="#FF9500" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Column="4"
                                           Text="of NET realized trading P&amp;L into the passive engine"
                                           FontSize="14" Foreground="#8090A8"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="6" Classes="PrimaryBtn"
                                        Content="SAVE RULE" Click="OnSaveRule"/>
                            </Grid>
                            <TextBlock FontSize="11" Foreground="#3A3000" TextWrapping="Wrap">
                                <Run FontWeight="Bold" Text="NET rule: "/>
                                <Run Text="Sweep is calculated from cumulative net P&amp;L across ALL closed trades (wins minus losses), not from each winning trade individually. This prevents sweeping during drawdowns and correctly nets out losses before the pump fires."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Available-to-sweep calculation -->
                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="20,16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="AVAILABLE TO SWEEP" Classes="SLabel"/>
                            <Grid ColumnDefinitions="*,1,*,1,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="NET REALIZED P&amp;L" Classes="SLabel"/>
                                    <TextBlock x:Name="SweepCalcNetPnl" Text="—"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#EBFFFF"/>
                                    <TextBlock Text="all closed trades, wins − losses"
                                               FontSize="10" Foreground="#2A3A4A"/>
                                </StackPanel>
                                <Rectangle Grid.Column="1" Fill="#141820" Width="1" Margin="16,0"/>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="ALREADY SWEPT" Classes="SLabel"/>
                                    <TextBlock x:Name="SweepCalcSwept" Text="—"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#BF1B1B"/>
                                    <TextBlock Text="total swept to passive engine"
                                               FontSize="10" Foreground="#2A3A4A"/>
                                </StackPanel>
                                <Rectangle Grid.Column="3" Fill="#141820" Width="1" Margin="16,0"/>
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="AVAILABLE (SWEEP FROM THIS)" Classes="SLabel"/>
                                    <TextBlock x:Name="SweepCalcAvailable" Text="—"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="#17A86C"/>
                                    <TextBlock x:Name="SweepCalcThisSweep" Text="—  at current rate"
                                               FontSize="10" Foreground="#2A3A4A"/>
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="DESTINATION" Classes="SLabel"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ComboBox x:Name="SweepDestSleeve"
                                                  Width="160" FontSize="11"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Index Core (VTI/SPY)"/>
                                            <ComboBoxItem Content="Dividend Growth"/>
                                        </ComboBox>
                                        <Border Background="#060810" BorderBrush="#141820"
                                                BorderThickness="1" CornerRadius="4" Padding="8,5">
                                            <TextBox x:Name="SweepDestSymbol"
                                                     Watermark="symbol (e.g. VTI)"
                                                     Background="Transparent" BorderThickness="0"
                                                     Foreground="#EBFFFF" FontSize="11"
                                                     Width="120"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <Button x:Name="ExecuteSweepBtn"
                                        Grid.Column="1"
                                        Classes="SweepBtn"
                                        Content="▶ EXECUTE SWEEP"
                                        IsEnabled="False"
                                        VerticalAlignment="Bottom"
                                        Click="OnExecuteSweep"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Sweep history -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                        <TextBlock Grid.Column="0" Text="SWEEP HISTORY"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#2A3240" LetterSpacing="1"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="0">
                        <StackPanel Spacing="0">
                            <Grid ColumnDefinitions="100,110,80,100,110,70,*"
                                  Margin="16,10,16,8">
                                <TextBlock Grid.Column="0" Text="DATE"        Classes="SLabel"/>
                                <TextBlock Grid.Column="1" Text="NET P&amp;L BASIS" Classes="SLabel"/>
                                <TextBlock Grid.Column="2" Text="RATE"        Classes="SLabel"/>
                                <TextBlock Grid.Column="3" Text="AMOUNT SWEPT" Classes="SLabel"/>
                                <TextBlock Grid.Column="4" Text="DESTINATION" Classes="SLabel"/>
                                <TextBlock Grid.Column="5" Text="SHARES"      Classes="SLabel"/>
                                <TextBlock Grid.Column="6" Text="NOTES"       Classes="SLabel"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#141820"/>

                            <Border x:Name="SweepEmpty" Padding="16,20">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="No sweeps executed yet."
                                               FontSize="12" Foreground="#2A3240"/>
                                    <TextBlock FontSize="11" Foreground="#1A2430">
                                        Log net realized trading P&amp;L and execute your first sweep to start compounding.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <ListBox x:Name="SweepList"
                                     Background="Transparent" IsVisible="False">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="local:SweepRow">
                                        <Grid ColumnDefinitions="100,110,80,100,110,70,*"
                                              Margin="16,8,16,8">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Date}"
                                                       FontSize="12" Foreground="#8090A8"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding NetPnl}"
                                                       FontSize="12" Foreground="#6070A0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SweepPct}"
                                                       FontSize="12" Foreground="#FF9500"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Amount}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#17A86C"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Destination}"
                                                       FontSize="12" Foreground="#EBFFFF"/>
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding SharesStr}"
                                                       FontSize="12" Foreground="#6070A0"/>
                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding Notes}"
                                                       FontSize="12" Foreground="#3A4A5A"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── DG SCREEN ──────────────────────────────────────────────── -->
                <StackPanel x:Name="DGPanel" IsVisible="False"
                            Margin="28,20,28,28" Spacing="16">

                    <!-- Yield-trap warning -->
                    <Border Background="#0C0A00" BorderBrush="#3A3000"
                            BorderThickness="1" CornerRadius="6" Padding="16,12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚠" FontSize="14" Foreground="#FFE101"
                                       VerticalAlignment="Center"/>
                            <TextBlock FontSize="11" Foreground="#8090A8"
                                       TextWrapping="Wrap" VerticalAlignment="Center">
                                <Run FontWeight="Bold" Text="Yield trap: "/>
                                <Run Text="Results sort by SAFETY + GROWTH, not current yield. A 9% yield that gets cut is worth less than a 2.5% yield growing at 12%/yr. Optimize for dividend safety and growth rate; let yield-on-cost compound naturally."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Filter controls -->
                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="18,14">
                        <StackPanel Spacing="12">
                            <TextBlock Text="SAFETY + GROWTH FILTERS" Classes="SLabel"/>
                            <Grid ColumnDefinitions="*,16,*,16,*,16,*">
                                <!-- Div streak -->
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="DIV STREAK (min yrs)" Classes="SLabel"/>
                                    <Border Background="#060810" BorderBrush="#141820"
                                            BorderThickness="1" CornerRadius="3" Padding="8,5">
                                        <TextBox x:Name="DGStreakMin" Text="5"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#EBFFFF" FontSize="12"/>
                                    </Border>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="FilterChip" Content="5+" Tag="5" Margin="0,0,4,0" Click="OnDGPreset"/>
                                        <Button Classes="FilterChip" Content="10+" Tag="10" Margin="0,0,4,0" Click="OnDGPreset"/>
                                        <Button Classes="FilterChip" Content="25+" Tag="25" Click="OnDGPreset"/>
                                    </WrapPanel>
                                </StackPanel>
                                <!-- 5Y CAGR -->
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="5Y DIV CAGR (min %)" Classes="SLabel"/>
                                    <Border Background="#060810" BorderBrush="#141820"
                                            BorderThickness="1" CornerRadius="3" Padding="8,5">
                                        <TextBox x:Name="DGCAGRMin" Text="7"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#EBFFFF" FontSize="12"/>
                                    </Border>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="FilterChip" Content="5%+" Tag="5" Margin="0,0,4,0" Click="OnDGCAGRPreset"/>
                                        <Button Classes="FilterChip" Content="8%+" Tag="8" Margin="0,0,4,0" Click="OnDGCAGRPreset"/>
                                        <Button Classes="FilterChip" Content="12%+" Tag="12" Click="OnDGCAGRPreset"/>
                                    </WrapPanel>
                                </StackPanel>
                                <!-- Payout ratio -->
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="PAYOUT RATIO (max %)" Classes="SLabel"/>
                                    <Border Background="#060810" BorderBrush="#141820"
                                            BorderThickness="1" CornerRadius="3" Padding="8,5">
                                        <TextBox x:Name="DGPayoutMax" Text="65"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#EBFFFF" FontSize="12"/>
                                    </Border>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="FilterChip" Content="&lt;50%" Tag="50" Margin="0,0,4,0" Click="OnDGPayoutPreset"/>
                                        <Button Classes="FilterChip" Content="&lt;65%" Tag="65" Margin="0,0,4,0" Click="OnDGPayoutPreset"/>
                                        <Button Classes="FilterChip" Content="&lt;80%" Tag="80" Click="OnDGPayoutPreset"/>
                                    </WrapPanel>
                                </StackPanel>
                                <!-- Yield min -->
                                <StackPanel Grid.Column="6" Spacing="4">
                                    <TextBlock Text="CURRENT YIELD (min %)" Classes="SLabel"/>
                                    <Border Background="#060810" BorderBrush="#141820"
                                            BorderThickness="1" CornerRadius="3" Padding="8,5">
                                        <TextBox x:Name="DGYieldMin" Text="1.5"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="#EBFFFF" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="secondary filter — not the primary sort"
                                               FontSize="9" Foreground="#2A3240"/>
                                </StackPanel>
                            </Grid>

                            <!-- Safety + sector row -->
                            <Grid ColumnDefinitions="Auto,24,Auto,24,*,24,Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="DIV SAFETY" Classes="SLabel"/>
                                    <WrapPanel Orientation="Horizontal">
                                        <Button x:Name="DGSafetyAny"   Classes="FilterChip Active" Content="ANY"        Tag="any"        Margin="0,0,4,0" Click="OnDGSafetyFilter"/>
                                        <Button x:Name="DGSafetySafe"  Classes="FilterChip"        Content="SAFE"       Tag="safe"       Margin="0,0,4,0" Click="OnDGSafetyFilter"/>
                                        <Button x:Name="DGSafetyBL"    Classes="FilterChip"        Content="BORDERLINE" Tag="borderline" Click="OnDGSafetyFilter"/>
                                    </WrapPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="SECTOR" Classes="SLabel"/>
                                    <ComboBox x:Name="DGSectorFilter" Width="150"
                                              FontSize="11" SelectedIndex="0">
                                        <ComboBoxItem Content="All Sectors"/>
                                        <ComboBoxItem Content="Consumer Staples"/>
                                        <ComboBoxItem Content="Healthcare"/>
                                        <ComboBoxItem Content="Utilities"/>
                                        <ComboBoxItem Content="Industrials"/>
                                        <ComboBoxItem Content="Financials"/>
                                        <ComboBoxItem Content="Real Estate"/>
                                        <ComboBoxItem Content="Energy"/>
                                        <ComboBoxItem Content="Technology"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="4">
                                    <TextBlock Text="MKT CAP" Classes="SLabel"/>
                                    <ComboBox x:Name="DGMktCapFilter" Width="140"
                                              FontSize="11" SelectedIndex="0">
                                        <ComboBoxItem Content="Any Size"/>
                                        <ComboBoxItem Content="Large Cap (>$10B)"/>
                                        <ComboBoxItem Content="Mid Cap ($2B–$10B)"/>
                                        <ComboBoxItem Content="Small Cap (&lt;$2B)"/>
                                    </ComboBox>
                                </StackPanel>
                                <Button Grid.Column="6" Classes="SweepBtn"
                                        Content="▶ SCREEN"
                                        Click="OnRunDGScreen"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Results -->
                    <Border Background="#08090E" BorderBrush="#141820"
                            BorderThickness="1" CornerRadius="6" Padding="0">
                        <StackPanel Spacing="0">
                            <Grid ColumnDefinitions="80,160,70,80,70,70,70,70,*"
                                  Margin="16,10,16,8">
                                <TextBlock Grid.Column="0" Text="SYMBOL"         Classes="SLabel"/>
                                <TextBlock Grid.Column="1" Text="COMPANY"        Classes="SLabel"/>
                                <TextBlock Grid.Column="2" Text="YIELD"          Classes="SLabel"/>
                                <TextBlock Grid.Column="3" Text="5Y CAGR"        Classes="SLabel"/>
                                <TextBlock Grid.Column="4" Text="STREAK"         Classes="SLabel"/>
                                <TextBlock Grid.Column="5" Text="PAYOUT"         Classes="SLabel"/>
                                <TextBlock Grid.Column="6" Text="FCF COV"        Classes="SLabel"/>
                                <TextBlock Grid.Column="7" Text="SAFETY"         Classes="SLabel"/>
                                <TextBlock Grid.Column="8" Text="SCORE ▼"        Classes="SLabel"/>
                            </Grid>
                            <Rectangle Height="1" Fill="#141820"/>

                            <Border x:Name="DGEmpty" Padding="16,20">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Run the screen to see results."
                                               FontSize="12" Foreground="#2A3240"/>
                                    <TextBlock FontSize="11" Foreground="#1A2430">
                                        Set your safety + growth criteria above, then click ▶ SCREEN.
                                        Results sort by composite safety/growth score, not by yield.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <ListBox x:Name="DGList"
                                     Background="Transparent" IsVisible="False">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="local:DGRow">
                                        <Grid ColumnDefinitions="80,160,70,80,70,70,70,70,*"
                                              Margin="16,8,16,8">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Symbol}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="#EBFFFF"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Company}"
                                                       FontSize="11" Foreground="#6070A0"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Yield}"
                                                       FontSize="12" Foreground="#8090A8"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Cagr5Y}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#17A86C"/>
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding Streak}"
                                                       FontSize="12" Foreground="#8090A8"/>
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding Payout}"
                                                       FontSize="12" Foreground="#8090A8"/>
                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding FcfCoverage}"
                                                       FontSize="12" Foreground="#8090A8"/>
                                            <Border Grid.Column="7"
                                                    Background="{Binding SafetyBg}"
                                                    CornerRadius="3" Padding="5,2"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SafetyLabel}"
                                                           FontSize="8" FontWeight="Bold"
                                                           Foreground="{Binding SafetyColor}"/>
                                            </Border>
                                            <TextBlock Grid.Column="8"
                                                       Text="{Binding Score}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{Binding ScoreColor}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
