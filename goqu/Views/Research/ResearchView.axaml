<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:goqu.Views.Research"
             x:Class="goqu.Views.Research.ResearchView"
             Background="#0A0A0A">

    <UserControl.Styles>

        <!-- ── Tree navigation items ── -->
        <Style Selector="Button.TreeItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6070A0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="3,*">
                        <Rectangle x:Name="ActiveBar" Grid.Column="0" Fill="Transparent"/>
                        <Border Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.TreeItem:pointerover">
            <Setter Property="Background" Value="#0C1020"/>
            <Setter Property="Foreground" Value="#AABBC8"/>
        </Style>
        <Style Selector="Button.TreeItem:pressed">
            <Setter Property="Background" Value="#0A0E1C"/>
        </Style>
        <Style Selector="Button.TreeItem.Active">
            <Setter Property="Background" Value="#061428"/>
            <Setter Property="Foreground" Value="#EBFFFF"/>
        </Style>
        <Style Selector="Button.TreeItem.Active /template/ Rectangle#ActiveBar">
            <Setter Property="Fill" Value="#0085CD"/>
        </Style>
        <Style Selector="Button.TreeItem.Active:pointerover">
            <Setter Property="Background" Value="#081830"/>
        </Style>

        <!-- ── Dossier recent card ── -->
        <Style Selector="Button.DossierCard">
            <Setter Property="Background" Value="#0E1016"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#191D26"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.DossierCard:pointerover">
            <Setter Property="Background" Value="#12161F"/>
            <Setter Property="BorderBrush" Value="#252C3A"/>
        </Style>

        <!-- ── New Dossier button ── -->
        <Style Selector="Button.NewDossier">
            <Setter Property="Background" Value="#0085CD"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.NewDossier:pointerover">
            <Setter Property="Background" Value="#0096E8"/>
        </Style>
        <Style Selector="Button.NewDossier:pressed">
            <Setter Property="Background" Value="#0074B4"/>
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="240,1,*">

        <!-- ════════════════════════════════════════════════════════
             LEFT — File Explorer Tree
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#090B12"
                BorderBrush="#141820"
                BorderThickness="0,0,0,0">
            <Grid RowDefinitions="Auto,1,*">

                <!-- Tree search -->
                <Border Grid.Row="0" Padding="10,10,10,10">
                    <TextBox x:Name="TreeSearch"
                             PlaceholderText="Filter..."
                             FontSize="12"
                             Height="30"
                             Padding="10,4"
                             TextChanged="OnTreeSearchChanged"/>
                </Border>

                <Rectangle Grid.Row="1" Fill="#141820"/>

                <!-- Tree items -->
                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,6,0,12">

                        <!-- All Research -->
                        <Button x:Name="TreeAll"
                                Classes="TreeItem Active"
                                Click="OnTreeAll">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="All Research"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#0D1520" CornerRadius="10"
                                        Padding="6,1" Margin="0,0,2,0">
                                    <TextBlock x:Name="CountAll"
                                               Text="0"
                                               FontSize="10" Foreground="#2A4060"/>
                                </Border>
                            </Grid>
                        </Button>

                        <Rectangle Height="1" Fill="#141820" Margin="16,6,16,6"/>

                        <!-- Sectors section -->
                        <TextBlock Text="SECTORS"
                                   FontSize="8" FontWeight="Bold"
                                   Foreground="#1C2430"
                                   LetterSpacing="1"
                                   Margin="19,4,0,4"/>

                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Technology">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Technology" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" x:Name="CountTech"
                                           Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Healthcare">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Healthcare" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Financials">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Financials" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Consumer Disc.">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Consumer Disc." VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Consumer Staples">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Consumer Staples" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Energy">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Energy" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Industrials">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Industrials" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Materials">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Materials" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Comm. Services">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Comm. Services" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Real Estate">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Real Estate" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="Utilities">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Utilities" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>

                        <Rectangle Height="1" Fill="#141820" Margin="16,6,16,6"/>

                        <!-- Themes / tags section -->
                        <TextBlock Text="THEMES"
                                   FontSize="8" FontWeight="Bold"
                                   Foreground="#1C2430"
                                   LetterSpacing="1"
                                   Margin="19,4,0,4"/>

                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="#watchlist">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="#watchlist" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="#earnings">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="#earnings" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="#options-candidate">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="#options-candidate" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="#macro">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="#macro" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>
                        <Button Classes="TreeItem" Click="OnTreeFilter" Tag="#dividend-growth">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="#dividend-growth" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="0" FontSize="10" Foreground="#1C2430" Margin="0,0,4,0"/>
                            </Grid>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>

        <Rectangle Grid.Column="1" Fill="#141820"/>

        <!-- ════════════════════════════════════════════════════════
             RIGHT — Main content
             ════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2" RowDefinitions="56,1,*">

            <!-- Header row -->
            <Grid Grid.Row="0" Margin="24,0,24,0" ColumnDefinitions="Auto,24,*,16,Auto">

                <!-- Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="RESEARCH"
                               FontSize="14" FontWeight="Black"
                               Foreground="#EBFFFF"
                               LetterSpacing="1"/>
                    <TextBlock x:Name="SubtitleLabel"
                               Text="per-symbol dossiers"
                               FontSize="10"
                               Foreground="#2A3A50"/>
                </StackPanel>

                <!-- Search bar -->
                <Border Grid.Column="2"
                        Background="#0C0F18"
                        BorderBrush="#1A2030"
                        BorderThickness="1"
                        CornerRadius="4"
                        VerticalAlignment="Center"
                        Height="30">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0"
                                   Text="/"
                                   FontSize="11" Foreground="#2A3A50"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <TextBox Grid.Column="1"
                                 x:Name="GlobalSearch"
                                 PlaceholderText="Search symbols, companies, themes..."
                                 FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,4"
                                 TextChanged="OnGlobalSearchChanged"/>
                    </Grid>
                </Border>

                <!-- New dossier button -->
                <Button Grid.Column="4"
                        Classes="NewDossier"
                        Content="+ NEW DOSSIER"
                        Click="OnNewDossier"
                        VerticalAlignment="Center"/>

            </Grid>

            <Rectangle Grid.Row="1" Fill="#141820"/>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,24,24,36" Spacing="28">

                    <!-- ── RECENT section ── -->
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="RECENT"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#1C2430"
                                       LetterSpacing="1"
                                       VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="10" Fill="#1C2430" VerticalAlignment="Center"/>
                            <TextBlock Text="last opened"
                                       FontSize="9" Foreground="#141C28"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Recent cards: horizontal scroll -->
                        <ScrollViewer x:Name="RecentScroll"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="RecentCards"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                <!-- Populated at runtime, or show empty state below -->
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Empty state (hidden when cards exist) -->
                        <Border x:Name="RecentEmpty"
                                Background="#0C0F14"
                                BorderBrush="#141820"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="20,16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="No dossiers yet."
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#2A3A50"/>
                                <TextBlock Text="Create your first research dossier with + NEW DOSSIER above."
                                           FontSize="11" Foreground="#1C2430"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- ── ALL DOSSIERS table ── -->
                    <StackPanel Spacing="10">

                        <!-- Section header + filter controls -->
                        <Grid ColumnDefinitions="Auto,*,Auto,8,Auto,8,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBlock Text="ALL DOSSIERS"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="#1C2430"
                                           LetterSpacing="1"
                                           VerticalAlignment="Center"/>
                                <Border Background="#0D1520" CornerRadius="10" Padding="7,2">
                                    <TextBlock x:Name="DossierCountLabel"
                                               Text="0 total"
                                               FontSize="9" Foreground="#1E3050"/>
                                </Border>
                            </StackPanel>

                            <!-- Outlook filter -->
                            <ComboBox Grid.Column="2"
                                      x:Name="OutlookFilter"
                                      SelectedIndex="0"
                                      FontSize="11" Height="28" MinWidth="110"
                                      SelectionChanged="OnFilterChanged">
                                <ComboBoxItem Content="All Outlooks"/>
                                <ComboBoxItem Content="Bullish"/>
                                <ComboBoxItem Content="Neutral"/>
                                <ComboBoxItem Content="Bearish"/>
                            </ComboBox>

                            <!-- Sort -->
                            <ComboBox Grid.Column="4"
                                      x:Name="SortBy"
                                      SelectedIndex="0"
                                      FontSize="11" Height="28" MinWidth="120"
                                      SelectionChanged="OnFilterChanged">
                                <ComboBoxItem Content="Sort: Recently Updated"/>
                                <ComboBoxItem Content="Sort: Symbol A–Z"/>
                                <ComboBoxItem Content="Sort: Conviction"/>
                                <ComboBoxItem Content="Sort: Sector"/>
                            </ComboBox>
                        </Grid>

                        <!-- Column headers -->
                        <Grid ColumnDefinitions="80,*,140,90,100,110">
                            <TextBlock Grid.Column="0" Text="SYMBOL"
                                       FontSize="8" FontWeight="Bold" Foreground="#1E2830" Margin="8,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="COMPANY"
                                       FontSize="8" FontWeight="Bold" Foreground="#1E2830"/>
                            <TextBlock Grid.Column="2" Text="SECTOR"
                                       FontSize="8" FontWeight="Bold" Foreground="#1E2830"/>
                            <TextBlock Grid.Column="3" Text="OUTLOOK"
                                       FontSize="8" FontWeight="Bold" Foreground="#1E2830"/>
                            <TextBlock Grid.Column="4" Text="CONVICTION"
                                       FontSize="8" FontWeight="Bold" Foreground="#1E2830"/>
                            <TextBlock Grid.Column="5" Text="UPDATED"
                                       FontSize="8" FontWeight="Bold" Foreground="#1E2830"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#141820"/>

                        <!-- Dossier rows -->
                        <ListBox x:Name="DossierList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsVisible="False"
                                 SelectionChanged="OnDossierSelected">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Height" Value="36"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#0C1020"/>
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#081428"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="local:DossierRow">
                                    <Grid ColumnDefinitions="80,*,140,90,100,110">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Symbol}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#EBFFFF"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CompanyName}"
                                                   FontSize="12" Foreground="#8090A8"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Sector}"
                                                   FontSize="11" Foreground="#4A5A70"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="3"
                                                Background="{Binding OutlookBg}"
                                                CornerRadius="2"
                                                Padding="6,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding OutlookLabel}"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="{Binding OutlookFg}"/>
                                        </Border>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding ConvictionStars}"
                                                   FontSize="11" Foreground="#0085CD"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding UpdatedAt}"
                                                   FontSize="11" Foreground="#3A4A60"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state for table -->
                        <StackPanel x:Name="DossierEmpty"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    Margin="0,40,0,20">
                            <TextBlock Text="No research dossiers yet."
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#1E2A3A"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Use + NEW DOSSIER to create your first per-symbol research note."
                                       FontSize="12" Foreground="#141C28"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Dossiers link to your trade journal via source_ref and theme tags."
                                       FontSize="11" Foreground="#10161E"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </Grid>

    </Grid>
</UserControl>
