<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="goqu.MainWindow"
        Title="GOQU"
        Background="#0A0A0A"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>

        <!-- ── Nav sidebar button ── -->
        <Style Selector="Button.NavItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8090A8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="19,11"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid ColumnDefinitions="3,*">
                        <Rectangle x:Name="ActiveBar" Grid.Column="0" Fill="Transparent"/>
                        <Border Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.NavItem:pointerover">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="Foreground" Value="#C8CDD8"/>
        </Style>
        <Style Selector="Button.NavItem:pressed">
            <Setter Property="Background" Value="#0D1018"/>
            <Setter Property="Foreground" Value="#EBFFFF"/>
        </Style>
        <!-- Active: green left bar + bright text -->
        <Style Selector="Button.NavItem.Active">
            <Setter Property="Background" Value="#0A1A10"/>
            <Setter Property="Foreground" Value="#EBFFFF"/>
        </Style>
        <Style Selector="Button.NavItem.Active /template/ Rectangle#ActiveBar">
            <Setter Property="Fill" Value="#038C4C"/>
        </Style>
        <Style Selector="Button.NavItem.Active:pointerover">
            <Setter Property="Background" Value="#0C1F14"/>
        </Style>

        <!-- ── Primary (green CTA) button ── -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#00D632"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#00EC3C"/>
        </Style>
        <Style Selector="Button.Primary:pressed">
            <Setter Property="Background" Value="#00B82A"/>
        </Style>

    </Window.Styles>

    <Grid>

        <!-- ══════════════════════════════════════════════════════════
             SETUP PANEL  —  visible when no account row exists in DB
             ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="SetupPanel" IsVisible="True">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#0A0A0A" Offset="0"/>
                    <GradientStop Color="#0C0F18" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border MaxWidth="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#111318"
                    CornerRadius="6"
                    BorderBrush="#20242E"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Green top accent bar -->
                    <Rectangle Grid.Row="0" Fill="#00D632"/>

                    <!-- Form body -->
                    <StackPanel Grid.Row="1" Margin="40,32,40,36" Spacing="20">

                        <!-- Branding -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="GOQU"
                                       FontSize="26" FontWeight="Black"
                                       Foreground="#00D632"/>
                            <TextBlock Text="TRADING JOURNAL  ·  RESEARCH  ·  EDGE DISCOVERY"
                                       FontSize="8" FontWeight="Medium"
                                       Foreground="#EBFFFF"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="#1C2028"/>

                        <TextBlock Text="Create your account"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#C8CDD8"/>

                        <!-- Account Name -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="ACCOUNT NAME"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#EBFFFF"/>
                            <TextBox x:Name="AccountNameInput"
                                     PlaceholderText="e.g. Main Taxable Account"
                                     Padding="12,10"
                                     FontSize="13"/>
                        </StackPanel>

                        <!-- Base Currency -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="BASE CURRENCY"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#EBFFFF"/>
                            <ComboBox x:Name="CurrencyComboBox"
                                      SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      FontSize="13">
                                <ComboBoxItem Content="USD — US Dollar"/>
                                <ComboBoxItem Content="EUR — Euro"/>
                                <ComboBoxItem Content="GBP — British Pound"/>
                                <ComboBoxItem Content="CAD — Canadian Dollar"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Alpha Vantage API Key -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="ALPHA VANTAGE API KEY"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="#EBFFFF"/>
                                <TextBlock Text="optional"
                                           FontSize="9"
                                           Foreground="#252A34"/>
                            </StackPanel>
                            <TextBox x:Name="ApiKeyInput"
                                     PlaceholderText="Paste your key — can be added later"
                                     PasswordChar="•"
                                     Padding="12,10"
                                     FontSize="13"/>
                        </StackPanel>

                        <!-- Notes -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="NOTES"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="#EBFFFF"/>
                                <TextBlock Text="optional"
                                           FontSize="9"
                                           Foreground="#EBFFFF"/>
                            </StackPanel>
                            <TextBox x:Name="NotesInput"
                                     PlaceholderText="e.g. Schwab taxable, IRA..."
                                     Padding="12,10"
                                     FontSize="13"/>
                        </StackPanel>

                        <!-- Error message -->
                        <TextBlock x:Name="SetupError"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#FF4C4C"
                                   IsVisible="False"
                                   TextWrapping="Wrap"/>

                        <!-- Submit -->
                        <Button Classes="Primary"
                                Content="CREATE ACCOUNT"
                                Click="OnCreateAccount"/>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════
             DASHBOARD PANEL  —  visible once an account exists
             ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="DashboardPanel" IsVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Sidebar ── -->
            <Border Grid.Column="0"
                    Background="#0E1016"
                    BorderBrush="#191D26"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo + account label -->
                    <StackPanel Grid.Row="0" Margin="22,22,22,18" Spacing="3">
                        <TextBlock Text="GOQU"
                                   FontSize="17" FontWeight="Black"
                                   Foreground="#00D632"/>
                        <TextBlock x:Name="SidebarAccountName"
                                   Text=""
                                   FontSize="11"
                                   Foreground="#6070A0"/>
                    </StackPanel>

                    <Rectangle Grid.Row="1" Fill="#191D26"/>

                    <!-- Nav items -->
                    <StackPanel Grid.Row="2" Margin="0,6,0,0">
                        <Button x:Name="NavHome"
                                Classes="NavItem"
                                Content="Home"
                                Click="OnNavHome"/>
                        <Rectangle Height="1" Fill="#191D26" Margin="0,6,0,6"/>
                        <TextBlock Text="MODULES"
                                   FontSize="8" FontWeight="Bold"
                                   Foreground="#2A3040"
                                   LetterSpacing="1"
                                   Margin="22,4,0,4"/>
                        <Button x:Name="NavJournal"   Classes="NavItem" Content="Trade Journal" Click="OnNavJournal"/>
                        <Button x:Name="NavResearch"  Classes="NavItem" Content="Research"       Click="OnNavResearch"/>
                        <Button x:Name="NavEdge"      Classes="NavItem" Content="Edge Discovery" Click="OnNavEdge"/>
                        <Button x:Name="NavQuant"     Classes="NavItem" Content="Quant Analysis" Click="OnNavQuant"/>
                        <Button x:Name="NavScreener"  Classes="NavItem" Content="Screener"       Click="OnNavScreener"/>
                        <Button x:Name="NavIncome"    Classes="NavItem" Content="Income / Sweep" Click="OnNavIncome"/>
                    </StackPanel>

                    <Rectangle Grid.Row="3" Fill="#191D26"/>

                    <!-- Footer: settings + status -->
                    <StackPanel Grid.Row="4" Margin="0,4,0,0">
                        <Button x:Name="NavSettings" Classes="NavItem" Content="Settings"/>
                        <StackPanel Orientation="Horizontal"
                                    Margin="22,6,22,16" Spacing="6">
                            <Ellipse Width="5" Height="5" Fill="#FF9500"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="v0.1.0  ·  DB CONNECTED"
                                       FontSize="9"
                                       Foreground="#FF9500"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main content area ── -->
            <ContentControl x:Name="MainContent" Grid.Column="1" Background="#0A0A0A">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <TextBlock Text="Select a module"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#1C2028"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose a section from the sidebar to get started."
                               FontSize="12"
                               Foreground="#1C2028"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </ContentControl>
        </Grid>

    </Grid>
</Window>
